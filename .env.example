# Copy this file to `.env` and fill in the values.
# Prisma CLI and Next.js both read `.env`.
#
# Leave DATABASE_URL / NEXT_PUBLIC_SUPABASE_URL blank (or don't create
# .env at all) and the app runs in Demo Mode — an in-memory backend with
# sample data and one-click logins, no external services required. See
# the README's "Preview it right now" section.

# ── Supabase ─────────────────────────────────────────────
# Supabase dashboard → Project Settings → Database → Connection string
# "Transaction" pooler URL goes in DATABASE_URL, "Session"/direct in DIRECT_URL
DATABASE_URL=""
DIRECT_URL=""
# Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Resend (needed in week 4 for emails — can stay empty) ─
RESEND_API_KEY=""
EMAIL_FROM="orders@example.com"
STAFF_NOTIFICATION_EMAILS=""

# ── Warehouse (from the C&G flyer; hours TBD) ────────────
WAREHOUSE_ADDRESS="9150 Latty Ave, Berkeley, MO 63134"
WAREHOUSE_PHONE="314-838-8588"
WAREHOUSE_HOURS="Mon-Fri 7:00 AM - 4:00 PM"
