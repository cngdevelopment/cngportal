# ============================================================
#  C&G Global — environment configuration
# ============================================================
#  Copy this file to `.env` and paste your keys in. Both the
#  Prisma CLI and Next.js read `.env`.
#
#  DEMO MODE: with DATABASE_URL and NEXT_PUBLIC_SUPABASE_URL
#  left blank, the app runs on an in-memory backend with sample
#  data and one-click logins — no external services required.
#  Fill in the Supabase block below and the app switches to the
#  real database automatically (see src/lib/mode.ts). Nothing
#  else to toggle. Full walkthrough: SETUP.md
# ============================================================

# ── 1. Supabase — Database ──────────────────────────────────
# Supabase dashboard -> Project Settings -> Database -> Connection string.
#   DATABASE_URL = the "Transaction" pooler URL (port 6543), add ?pgbouncer=true
#   DIRECT_URL   = the "Session"/direct URL (port 5432), used for migrations
DATABASE_URL=""
DIRECT_URL=""

# ── 2. Supabase — API keys ──────────────────────────────────
# Supabase dashboard -> Project Settings -> API.
#   NEXT_PUBLIC_SUPABASE_URL      = Project URL (https://xxxx.supabase.co)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY = anon / public key (safe for the browser)
#   SUPABASE_SERVICE_ROLE_KEY     = service_role key (server only — NEVER expose)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── 3. App ──────────────────────────────────────────────────
# Public base URL of the deployed site (used for magic-link redirects).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── 4. Resend — transactional email (optional until go-live) ─
# resend.com -> API Keys. EMAIL_FROM must be on a verified domain.
# STAFF_NOTIFICATION_EMAILS: comma-separated recipients for new-order alerts.
RESEND_API_KEY=""
EMAIL_FROM="orders@example.com"
STAFF_NOTIFICATION_EMAILS=""

# ── 5. Warehouse / pickup (seed defaults) ───────────────────
# These seed the defaults. After signing in, edit them in
# Admin -> Settings instead of here.
WAREHOUSE_ADDRESS="9150 Latty Ave, Berkeley, MO 63134"
WAREHOUSE_PHONE="314-838-8588"
WAREHOUSE_HOURS="Mon-Fri 7:00 AM - 4:00 PM"
